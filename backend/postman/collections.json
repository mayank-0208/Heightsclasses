      "info": {
        "name": "02 - Authentication",
        "description": "Login, logout, password management, and user CRUD (Admin only)",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
      },
      "variable": [
        { "key": "baseUrl", "value": "http://localhost:5001/api/v1" },
        { "key": "accessToken", "value": "" },
        { "key": "userId", "value": "" },
        { "key": "teacherId", "value": "" }
      ],
      "auth": {
        "type": "bearer",
        "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
      },
      "item": [
        {
          "name": "Login (Admin)",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "const res = pm.response.json();",
                "if (res.data?.accessToken) {",
                "  pm.environment.set('accessToken', res.data.accessToken);",
                "  pm.collectionVariables.set('accessToken', res.data.accessToken);",
                "}",
                "if (res.data?.refreshToken) pm.environment.set('refreshToken', res.data.refreshToken);",
                "if (res.data?.user?._id) {",
                "  pm.environment.set('userId', res.data.user._id);",
                "  pm.collectionVariables.set('userId', res.data.user._id);",
                "}"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@coaching.com\",\n  \"password\": \"Admin@12345\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/auth/login",
            "auth": { "type": "noauth" }
          }
        },
        {
          "name": "Login (Teacher)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
